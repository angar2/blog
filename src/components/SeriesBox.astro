---
// 글 머리 시리즈 박스 — 접힌 한 줄 "시리즈명 · n/m ▸" → 펼치면 연재 목차(현재 글 accent)
import type { SeriesMembership } from '../lib/content';

interface Props {
  membership: SeriesMembership;
  currentPostId: string;
}

const { membership, currentPostId } = Astro.props;
const { series, index, posts } = membership;
---

<details class="series-box">
  <summary>
    <span class="series-dot" aria-hidden="true"></span>
    <span class="series-title">
      {series.data.title}
      <span class="series-position">· {index + 1} / {posts.length}</span>
    </span>
    <span class="series-caret" aria-hidden="true"></span>
  </summary>
  <ol>
    {
      posts.map((p, i) => (
        <li aria-current={p.id === currentPostId ? 'true' : undefined}>
          {p.id === currentPostId ? (
            <span>{i + 1} — {p.data.title}</span>
          ) : (
            <a href={`/posts/${p.id}`}>{i + 1} — {p.data.title}</a>
          )}
        </li>
      ))
    }
  </ol>
</details>

<style>
  .series-box {
    margin: 16px 0;
    border: 1px solid var(--c-bd);
    border-radius: 10px;
    background: var(--c-bg2);
    overflow: hidden;
  }
  summary {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 11px 13px;
    cursor: pointer;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  .series-dot {
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--c-ac);
    flex: 0 0 auto;
  }
  .series-title {
    font: 700 13px/1.3 var(--font-sans);
    color: var(--c-tx);
  }
  .series-position {
    color: var(--c-tx3);
    font-weight: 500;
  }
  .series-caret {
    margin-left: auto;
    color: var(--c-tx3);
    font-size: 12px;
  }
  .series-caret::before {
    content: '▸';
  }
  details[open] .series-caret::before {
    content: '▾';
  }
  ol {
    list-style: none;
    margin: 0;
    padding: 0 13px 11px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  li {
    font: 500 12px/1.5 var(--font-sans);
    padding: 3px 0 3px 22px;
    position: relative;
  }
  li a {
    color: var(--c-tx3);
  }
  li[aria-current='true'] {
    font-weight: 700;
    color: var(--c-ac);
  }
  li[aria-current='true']::before {
    content: '▸';
    position: absolute;
    left: 2px;
  }
</style>
