---
// 프로젝트 카드 — 커버·제목·태그라인·스택 칩. Projects 목록과 홈 '최신 프로젝트'가 공유
import { Image } from 'astro:assets';
import type { Project } from '../lib/content';

interface Props {
  project: Project;
}

const { project: p } = Astro.props;
---

<a class="project-card" href={`/projects/${p.id}`}>
  <Image class="cover" src={p.data.cover} alt={`${p.data.title} 스크린샷`} />
  <span class="card-body">
    <span class="card-title">{p.data.title}</span>
    <span class="card-tagline">{p.data.tagline}</span>
    <span class="stack-chips">
      {p.data.stacks.map((stack) => <span class="chip">{stack}</span>)}
    </span>
  </span>
</a>

<style>
  .project-card {
    display: block;
    border: 1px solid var(--c-bd);
    border-radius: 14px;
    overflow: hidden;
    background: var(--c-bg2);
  }
  .project-card :global(.cover) {
    display: block;
    width: 100%;
    height: 88px;
    object-fit: cover;
  }
  .card-body {
    display: block;
    padding: 13px 14px 15px;
  }
  .card-title {
    display: block;
    font: 700 15px/1.2 var(--font-sans);
    color: var(--c-tx);
    margin-bottom: 5px;
  }
  .card-tagline {
    display: block;
    font: 500 12px/1.5 var(--font-sans);
    color: var(--c-tx2);
    margin-bottom: 11px;
    min-height: 2.4em;
  }
  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .chip {
    font: 600 10px/1 var(--font-mono);
    color: var(--c-tx3);
    border: 1px solid var(--c-bd);
    border-radius: 5px;
    padding: 4px 7px;
  }
</style>
