---
// 공통 레이아웃 — 헤더(로고+메뉴+테마 토글)·푸터·head 메타. 디자인: design_handoff §공통
import '../styles/tokens.css';
import '../styles/pretendard.css';
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** 헤더 메뉴 현재 페이지 표시용 */
  current?: 'log' | 'notes' | 'series' | 'projects' | 'about' | 'home';
  /** 본문 페이지는 넓은 컬럼(860px) 사용 */
  wide?: boolean;
}

const { title, description, current, wide = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const menu = [
  { key: 'log', label: 'Log', href: '/log' },
  { key: 'notes', label: 'Notes', href: '/notes' },
  { key: 'series', label: 'Series', href: '/series' },
  { key: 'projects', label: 'Projects', href: '/projects' },
  { key: 'about', label: 'About', href: '/about' },
] as const;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/avatar.png" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="angari.dev" href="/rss.xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <script is:inline>
      // FOUC 방지: 페인트 전에 저장된 테마 적용 (다크가 기본·1급)
      const saved = localStorage.getItem('theme');
      if (saved === 'light') document.documentElement.dataset.theme = 'light';
    </script>
    <slot name="head" />
  </head>
  <body>
    <header>
      <nav aria-label="주 메뉴">
        <a class="brand" href="/" aria-current={current === 'home' ? 'page' : undefined}>
          <img src="/avatar.png" alt="" width="30" height="30" />
          <span class="brand-name">angari<span class="brand-dot">.dev</span></span>
        </a>
        <ul>
          {
            menu.map((m) => (
              <li>
                <a href={m.href} aria-current={current === m.key ? 'page' : undefined}>
                  {m.label}
                </a>
              </li>
            ))
          }
          <li>
            <button id="theme-toggle" type="button" aria-label="라이트/다크 전환">◐</button>
          </li>
        </ul>
      </nav>
    </header>
    <main class:list={[{ wide }]}>
      <slot />
    </main>
    <footer>
      <span>© {new Date().getFullYear()} 지크 · angari.dev</span>
      <a href="https://github.com/angar2" rel="external noopener">GitHub ↗</a>
    </footer>
  </body>
</html>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 5;
    background: var(--c-bg);
    border-bottom: 1px solid var(--c-bd);
  }
  nav {
    max-width: var(--w-content);
    margin: 0 auto;
    padding: 14px 26px 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .brand img {
    border-radius: 50%;
    display: block;
  }
  .brand-name {
    font: 700 15px/1 var(--font-sans);
    color: var(--c-tx);
    letter-spacing: -0.01em;
  }
  .brand-dot {
    color: var(--c-ac);
  }
  nav ul {
    display: flex;
    gap: 2px;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav ul a {
    display: block;
    padding: 6px 10px;
    border-radius: 7px;
    font: 600 12.5px/1 var(--font-sans);
    color: var(--c-tx3);
  }
  nav ul a[aria-current='page'] {
    color: var(--c-tx);
    background: var(--c-acS);
  }
  #theme-toggle {
    border: none;
    background: none;
    color: var(--c-tx3);
    font-size: 14px;
    line-height: 1;
    padding: 6px 8px;
    border-radius: 7px;
    cursor: pointer;
  }
  #theme-toggle:hover {
    color: var(--c-tx);
    background: var(--c-acS);
  }

  main {
    flex: 1;
    width: 100%;
    max-width: var(--w-content);
    margin: 0 auto;
    padding: 0 26px 8px;
  }
  main.wide {
    max-width: var(--w-post);
  }

  footer {
    width: 100%;
    max-width: var(--w-content);
    margin: 24px auto 0;
    padding: 20px 26px 16px;
    border-top: 1px solid var(--c-bd);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  footer span {
    font: 500 11px/1.4 var(--font-sans);
    color: var(--c-tx3);
  }
  footer a {
    font: 600 11px/1 var(--font-sans);
    color: var(--c-tx3);
  }

  @media (max-width: 520px) {
    nav {
      flex-wrap: wrap;
      padding: 12px 16px;
    }
    main {
      padding: 0 16px 8px;
    }
    footer {
      padding: 20px 16px 14px;
    }
  }
</style>

<script>
  // 라이트/다크 토글 (허용 인터랙션 #6) — data-theme + localStorage 지속
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    if (next === 'light') root.dataset.theme = 'light';
    else delete root.dataset.theme;
    localStorage.setItem('theme', next);
  });
</script>
