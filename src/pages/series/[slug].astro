---
// 시리즈 상세 — 소개 문단 + 수록 글 순서 목록 + (연결 시) 완성품 보기
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { displayDate, resolveSeriesPosts, type Series } from '../../lib/content';

export async function getStaticPaths() {
  const series = await getCollection('series');
  return series.map((s) => ({ params: { slug: s.id }, props: { series: s } }));
}

interface Props {
  series: Series;
}

const { series } = Astro.props;
const { Content } = await render(series);
const posts = await resolveSeriesPosts(series);

// 완성품 보기 → 프로젝트 (역방향: 이 시리즈를 가리키는 프로젝트)
const projects = await getCollection('projects', (p) => p.data.series === series.id);
---

<Base title={`${series.data.title} · angari.dev`} description={series.data.description} current="series">
  <article>
    <header class="series-head">
      <a class="back-link" href="/series">← Series</a>
      <div class="kind-row">
        <span class="card-kind">◈ 시리즈</span>
        <span class="card-stats">{posts.length}편</span>
      </div>
      <h1 class="page-title">{series.data.title}</h1>
      <p class="page-desc">{series.data.description}</p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <ol class="series-posts" aria-label={`수록 글 ${posts.length}편`}>
      {
        posts.map((p, i) => (
          <li>
            <a href={`/posts/${p.id}`}>
              <span class="num">{i + 1}</span>
              <span class="title">{p.data.title}</span>
              <time datetime={p.data.created}>{displayDate(p.data.created)}</time>
            </a>
          </li>
        ))
      }
    </ol>

    {
      projects.map((p) => (
        <a class="project-link" href={`/projects/${p.id}`}>
          <span>
            <span class="pl-label">▤ 완성품</span>
            <span class="pl-title">{p.data.title} 보기</span>
          </span>
          <span class="pl-arrow">→</span>
        </a>
      ))
    }
  </article>
</Base>

<style>
  .series-head {
    padding: 16px 0 10px;
  }
  .back-link {
    color: var(--c-tx3);
    font: 600 12px/1 var(--font-sans);
  }
  .kind-row {
    display: flex;
    align-items: center;
    gap: 9px;
    margin: 14px 0 10px;
  }
  .card-kind {
    font: 700 10px/1 var(--font-sans);
    color: var(--c-ac);
    letter-spacing: 0.04em;
  }
  .card-stats {
    font: 600 11px/1 var(--font-mono);
    color: var(--c-tx3);
  }
  .prose {
    margin-bottom: 8px;
  }

  .series-posts {
    list-style: none;
    margin: 10px 0 0;
    padding: 0;
  }
  .series-posts li {
    border-top: 1px solid var(--c-bd);
  }
  .series-posts a {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 12px 0;
  }
  .series-posts .num {
    font: 600 12px/1 var(--font-mono);
    color: var(--c-tx3);
    width: 18px;
    flex: 0 0 auto;
  }
  .series-posts .title {
    font: 700 14px/1.4 var(--font-sans);
    color: var(--c-tx);
    min-width: 0;
  }
  .series-posts time {
    margin-left: auto;
    font: 500 11px/1 var(--font-mono);
    color: var(--c-tx3);
    flex: 0 0 auto;
  }

  .project-link {
    margin-top: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 14px 16px;
    border-radius: 12px;
    background: var(--c-bg2);
    border: 1px solid var(--c-bd);
  }
  .pl-label {
    display: block;
    font: 600 10px/1 var(--font-sans);
    color: var(--c-ac);
    margin-bottom: 5px;
  }
  .pl-title {
    display: block;
    font: 700 14px/1.3 var(--font-sans);
    color: var(--c-tx);
  }
  .pl-arrow {
    color: var(--c-ac);
    font-size: 18px;
  }
</style>
