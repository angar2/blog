---
// /series 시리즈 목록 페이지 — 시리즈 카드 리스트, 최신 갱신순 (build-prd §1·§4-1 개정 2026-07-12)
import Base from '../../layouts/Base.astro';
import { displayDate, getSeriesOverview } from '../../lib/content';

const overviews = await getSeriesOverview();
---

<Base title="Series · angari.dev" description="시리즈 목록 — 순서대로 읽는 글 묶음" current="series">
  <h1>Series</h1>
  <ul class="series-cards">
    {
      overviews.map(({ series, count, latestCreated }) => (
        <li class="series-card">
          <a href={`/series/${series.id}`}>{series.data.title}</a>
          <p>{series.data.description}</p>
          <span>{count}편</span>
          <time datetime={latestCreated}>최신 갱신 {displayDate(latestCreated)}</time>
        </li>
      ))
    }
  </ul>
  {overviews.length === 0 && <p>등록된 시리즈가 아직 없다.</p>}
</Base>
