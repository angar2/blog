---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TrackBadge from '../../components/TrackBadge.astro';
import SeriesBox from '../../components/SeriesBox.astro';
import TocRail from '../../components/TocRail.astro';
import {
  displayDate,
  getAllPosts,
  getRelatedProjects,
  getSeriesMemberships,
  type Post,
} from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const memberships = await getSeriesMemberships(post.id);
const relatedProjects = await getRelatedProjects(memberships.map((m) => m.series.id));

// JSON-LD: author=AI, 검수=지크를 정직하게 명시 — 정체성의 구조화 데이터 버전 (build-prd §4-2)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  url: new URL(`/posts/${post.id}`, Astro.site).href,
  datePublished: `${post.data.created}:00+09:00`,
  ...(post.data.updated && { dateModified: `${post.data.updated}:00+09:00` }),
  keywords: post.data.tags,
  author: { '@type': 'SoftwareApplication', name: 'Claude (AI)' },
  editor: { '@type': 'Person', name: 'angari (Zeke)', url: new URL('/about', Astro.site).href },
  inLanguage: 'ko',
};
---

<Base title={`${post.data.title} · angari.dev`} description={post.data.description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article>
    <!-- ① 머리 -->
    <header class="post-header">
      <TrackBadge track={post.data.track} />
      <h1>{post.data.title}</h1>
      <time datetime={post.data.created}>{displayDate(post.data.created)}</time>
      {
        post.data.updated && (
          <time class="updated" datetime={post.data.updated}>
            (개정 {displayDate(post.data.updated)})
          </time>
        )
      }
      <ul class="tag-list">
        {
          post.data.tags.map((tag) => (
            <li>
              <a href={`/tags/${tag}`}>#{tag}</a>
            </li>
          ))
        }
      </ul>
    </header>

    <!-- ② 시리즈 박스 (다중 소속이면 복수) -->
    {memberships.map((m) => <SeriesBox membership={m} currentPostId={post.id} />)}

    <!-- ③ 본문 + 우측 목차 레일 -->
    <TocRail headings={headings} />
    <div class="prose">
      <Content />
    </div>

    <!-- ④ 참고 자료 (notes 트랙은 항상 존재) -->
    {
      post.data.sources && post.data.sources.length > 0 && (
        <section class="sources">
          <h2>참고 자료</h2>
          <ul>
            {post.data.sources.map((s) => (
              <li>
                <a href={s.url} rel="external noopener">
                  {s.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- ⑤ 꼬리: 시리즈 내 이전/다음 · 관련 프로젝트 -->
    {
      memberships.map((m) => {
        const prev = m.index > 0 ? m.posts[m.index - 1] : null;
        const next = m.index < m.posts.length - 1 ? m.posts[m.index + 1] : null;
        return (
          <nav class="series-nav" aria-label={`${m.series.data.title} 연재 내비게이션`}>
            <span class="series-nav-title">{m.series.data.title}</span>
            {prev && (
              <a rel="prev" href={`/posts/${prev.id}`}>
                ← {prev.data.title}
              </a>
            )}
            {next && (
              <a rel="next" href={`/posts/${next.id}`}>
                {next.data.title} →
              </a>
            )}
          </nav>
        );
      })
    }
    {
      relatedProjects.length > 0 && (
        <nav class="related-projects" aria-label="관련 프로젝트">
          {relatedProjects.map((p) => (
            <a href={`/projects/${p.id}`}>완성품 보기 → {p.data.title}</a>
          ))}
        </nav>
      )
    }

    <!-- ⑥ 바이라인 — 겸손하지만 숨기지 않게 -->
    <footer class="byline">
      <p>작성 AI · 검수 지크 — <a href="/about">이 사이트의 글이 만들어지는 방식</a></p>
    </footer>
  </article>
</Base>

<script>
  // 코드 블록 복사 버튼 (허용 인터랙션 #2)
  document.querySelectorAll('.prose pre').forEach((pre) => {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = 'code-copy';
    button.textContent = '복사';
    button.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent ?? '';
      await navigator.clipboard.writeText(code);
      button.textContent = '복사됨';
      setTimeout(() => (button.textContent = '복사'), 1500);
    });
    pre.insertAdjacentElement('afterbegin', button);
  });
</script>
