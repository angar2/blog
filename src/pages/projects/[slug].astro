---
// 프로젝트 상세 — 큰 커버·제목/태그라인·스택 칩·소개·데모/GitHub 버튼·제작기 시리즈 카드
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import type { Project } from '../../lib/content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { Content } = await render(project);

const series = project.data.series ? await getEntry('series', project.data.series) : null;
if (project.data.series && !series) {
  throw new Error(
    `프로젝트 "${project.id}"가 존재하지 않는 시리즈 "${project.data.series}"를 참조한다 — 빌드 중단.`,
  );
}
---

<Base title={`${project.data.title} · angari.dev`} description={project.data.tagline} current="projects">
  <article>
    <div class="back-row">
      <a class="back-link" href="/projects">← Projects</a>
    </div>
    <Image class="big-cover" src={project.data.cover} alt={`${project.data.title} 스크린샷`} />
    <header class="proj-head">
      <h1>{project.data.title}</h1>
      <p class="tagline">{project.data.tagline}</p>
    </header>
    <div class="stack-chips" aria-label="기술 스택">
      {project.data.stacks.map((stack) => <span class="chip">{stack}</span>)}
    </div>

    <div class="prose">
      <Content />
    </div>

    <div class="links">
      {
        project.data.links?.demo && (
          <a class="btn-primary" href={project.data.links.demo} rel="external noopener">
            데모 열기 ↗
          </a>
        )
      }
      {
        project.data.links?.github && (
          <a class="btn-outline" href={project.data.links.github} rel="external noopener">
            GitHub ↗
          </a>
        )
      }
    </div>

    {
      series && (
        <a class="series-link" href={`/series/${series.id}`}>
          <span>
            <span class="sl-label">◈ 제작기</span>
            <span class="sl-title">{series.data.title} 시리즈 읽기</span>
          </span>
          <span class="sl-arrow">→</span>
        </a>
      )
    }
  </article>
</Base>

<style>
  .back-row {
    padding: 16px 0 12px;
  }
  .back-link {
    color: var(--c-tx3);
    font: 600 12px/1 var(--font-sans);
  }
  article :global(.big-cover) {
    display: block;
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 14px;
  }
  .proj-head {
    margin: 16px 0 6px;
  }
  .proj-head h1 {
    font: 800 24px/1.15 var(--font-sans);
    letter-spacing: -0.02em;
    color: var(--c-tx);
    margin: 0 0 6px;
  }
  .tagline {
    font: 500 14px/1.6 var(--font-sans);
    color: var(--c-tx2);
    margin: 0;
  }
  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 12px 0 16px;
  }
  .chip {
    font: 600 11px/1 var(--font-mono);
    color: var(--c-tx3);
    border: 1px solid var(--c-bd);
    border-radius: 6px;
    padding: 5px 9px;
  }
  .prose {
    margin-bottom: 20px;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-bottom: 18px;
  }
  .btn-primary {
    padding: 9px 14px;
    border-radius: 9px;
    background: var(--c-ac);
    color: var(--c-acT);
    font: 700 12px/1 var(--font-sans);
  }
  .btn-outline {
    padding: 9px 14px;
    border-radius: 9px;
    border: 1px solid var(--c-bd2);
    color: var(--c-tx);
    font: 700 12px/1 var(--font-sans);
  }
  .series-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 14px 16px;
    border-radius: 12px;
    background: var(--c-bg2);
    border: 1px solid var(--c-bd);
  }
  .sl-label {
    display: block;
    font: 600 10px/1 var(--font-sans);
    color: var(--c-ac);
    margin-bottom: 5px;
  }
  .sl-title {
    display: block;
    font: 700 14px/1.3 var(--font-sans);
    color: var(--c-tx);
  }
  .sl-arrow {
    color: var(--c-ac);
    font-size: 18px;
  }
</style>
