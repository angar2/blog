---
// Notes 목록 — 지식 트랙, 태그 칩 필터
import Base from '../layouts/Base.astro';
import PostList from '../components/PostList.astro';
import TrackBadge from '../components/TrackBadge.astro';
import { getPostsByTrack, getTagCounts } from '../lib/content';

const posts = await getPostsByTrack('notes');
const tags = await getTagCounts(posts);
---

<Base title="Notes · angari.dev" description="지식 트랙 — 개념 정리·삽질 해법" current="notes">
  <div class="list-head">
    <div class="title-row">
      <TrackBadge track="notes" />
      <h1 class="page-title">Notes</h1>
    </div>
    <p class="page-desc">개념 정리 · 삽질 해법. 태그로 걸러 보세요.</p>
  </div>

  <!-- 태그 칩 바 (글 수 많은 순) — 칩 클릭 = 필터 (허용 인터랙션 #3) -->
  {
    tags.length > 0 && (
      <div class="tag-chip-bar" role="group" aria-label="태그 필터">
        {tags.map(({ tag, count }) => (
          <button type="button" class="tag-chip" data-tag={tag} aria-pressed="false">
            #{tag} <span class="count">{count}</span>
          </button>
        ))}
      </div>
    )
  }

  <PostList posts={posts} />
</Base>

<style>
  .list-head {
    padding: 16px 0 6px;
  }
  .title-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .tag-chip-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    padding: 8px 0 4px;
  }
  .tag-chip {
    cursor: pointer;
    font: 600 11px/1 var(--font-mono);
    padding: 6px 9px;
    border-radius: 999px;
    border: 1px solid var(--c-bd);
    color: var(--c-tx2);
    background: transparent;
  }
  .tag-chip .count {
    opacity: 0.6;
  }
  .tag-chip[aria-pressed='true'] {
    border-color: var(--c-ac);
    color: var(--c-acT);
    background: var(--c-ac);
  }
</style>

<script>
  // 태그 칩 필터: 선택된 태그를 가진 글만 표시 (단일 선택 토글)
  const chips = document.querySelectorAll<HTMLButtonElement>('.tag-chip');
  const items = document.querySelectorAll<HTMLLIElement>('.post-item');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const active = chip.getAttribute('aria-pressed') === 'true';
      chips.forEach((c) => c.setAttribute('aria-pressed', 'false'));
      if (active) {
        items.forEach((item) => (item.hidden = false));
        return;
      }
      chip.setAttribute('aria-pressed', 'true');
      const tag = chip.dataset.tag ?? '';
      items.forEach((item) => {
        const tags = (item.dataset.tags ?? '').split(' ');
        item.hidden = !tags.includes(tag);
      });
    });
  });
</script>
